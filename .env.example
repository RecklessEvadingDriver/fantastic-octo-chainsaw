# Required
BOT_TOKEN=your_telegram_bot_token_here

# Admin user IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789,987654321

# Telegram channel/group ID for activity logs (leave 0 to disable)
# Use a negative ID for supergroups/channels, e.g. -1001234567890
LOG_CHANNEL_ID=0

# Optional access control — leave empty to allow all users
ALLOWED_USER_IDS=

# Force-join channel — users must join before using the bot (leave empty to disable)
# Accepts @username or https://t.me/joinchat/... invite link
FORCE_JOIN_CHANNEL=

# Working directories (relative or absolute paths)
DOWNLOAD_DIR=downloads
OUTPUT_DIR=outputs
FONTS_DIR=fonts

# SQLite database file
DATABASE_PATH=bot_data.db

# File splitting:
#   Files larger than SPLIT_THRESHOLD_MB are split into parts.
#   Standard Bot API max is ~50 MB; with a local API server up to 2000 MB / 4000 MB.
SPLIT_THRESHOLD_MB=2000
SPLIT_PART_SIZE_MB=1950

# Auto-delete bot messages from group chats after N seconds (0 = disabled)
AUTO_DELETE_GROUP_SECONDS=30
