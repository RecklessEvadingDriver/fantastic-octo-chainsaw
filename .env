# Required
BOT_TOKEN=8774632531:AAEze5K1ITqS6KLFc63v0zEQgumP2hEfgwo

# Pyrogram MTProto credentials (REQUIRED)
# Obtain your api_id and api_hash from https://my.telegram.org/apps
PYROGRAM_API_ID=31357715
PYROGRAM_API_HASH=b5dd77499558488d7b5a72cea9d8c6f8

# Admin user IDs (comma-separated Telegram user IDs)
ADMIN_IDS=8608872142

# Telegram channel/group ID for activity logs (leave 0 to disable)
# Use a negative ID for supergroups/channels, e.g. -1001234567890
LOG_CHANNEL_ID=-1003747919485

# Optional access control — leave empty to allow all users
ALLOWED_USER_IDS=

# Force-join channel — users must join before using the bot (leave empty to disable)
# Accepts @username or https://t.me/joinchat/... invite link
FORCE_JOIN_CHANNEL=

# Working directories (relative or absolute paths)
DOWNLOAD_DIR=downloads
OUTPUT_DIR=outputs
FONTS_DIR=fonts

# SQLite database file
DATABASE_PATH=bot_data.db

# File splitting:
#   Files larger than SPLIT_THRESHOLD_MB are split into parts before sending.
#   Standard Bot API sendDocument limit is 50 MB; use 49 MB to stay safely under.
#   With a local Bot API server (LOCAL_API_SERVER set) this can be raised to ~2000 MB.
SPLIT_THRESHOLD_MB=49
SPLIT_PART_SIZE_MB=45

# Auto-delete bot messages from group chats after N seconds (0 = disabled)
AUTO_DELETE_GROUP_SECONDS=30

# Heroku webhook settings
# Set WEBHOOK_URL to your Heroku app URL (e.g. https://your-app.herokuapp.com)
# Leave empty to use long-polling (for loca)
WEBHOOK_URL=https://fantastic-octo-chainsaw-3910022b0710.herokuapp.com
# PORT is automatically set by Heroku; no need to set it manually there
